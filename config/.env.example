# Algebrium local development defaults. Never put real tokens here.
ALGEBRIUM_ENV=development
QDRANT_URL=http://127.0.0.1:7333
QDRANT_COLLECTION=kb_math_v1
ALGEBRIUM_KB_PATH=data/algebrium.db
CAS_DOCKER_IMAGE=sagemath/sagemath:latest
CAS_TIMEOUT_SECONDS=30
LOG_LEVEL=info

# Configure only the key for the active profile in config.json.
DEEPSEEK_API_KEY=
MIMO_API_KEY=
KIMI_API_KEY=
ARK_API_KEY=
OPENROUTER_API_KEY=
SILICONFLOW_API_KEY=
