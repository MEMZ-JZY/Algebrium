{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Algebrium",
  "version": "0.1.0",
  "identifier": "com.algebrium.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Algebrium",
        "width": 980,
        "height": 720,
        "minWidth": 640,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src http://127.0.0.1:4097; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": false
  }
}
