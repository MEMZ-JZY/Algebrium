{
  "provider": {
    "mode": "real",
    "active": "deepseek",
    "profiles": {
      "deepseek": {
        "provider": "deepseek",
        "model": "deepseek-v4-flash",
        "apiKeyEnv": "DEEPSEEK_API_KEY",
        "maxTokens": 4096,
        "timeoutMs": 120000,
        "headers": {},
        "extraBody": {}
      },
      "mimo": {
        "provider": "mimo",
        "model": "mimo-v2.5-pro",
        "apiKeyEnv": "MIMO_API_KEY",
        "maxTokens": 4096,
        "timeoutMs": 120000,
        "headers": {},
        "extraBody": {}
      },
      "kimi": {
        "provider": "kimi",
        "model": "kimi-k2.7",
        "apiKeyEnv": "KIMI_API_KEY",
        "maxTokens": 4096,
        "timeoutMs": 120000,
        "headers": {},
        "extraBody": {}
      },
      "volcengine": {
        "provider": "volcengine",
        "model": "YOUR_ARK_ENDPOINT_OR_MODEL_ID",
        "apiKeyEnv": "ARK_API_KEY",
        "maxTokens": 4096,
        "timeoutMs": 120000,
        "headers": {},
        "extraBody": {}
      },
      "openrouter": {
        "provider": "openrouter",
